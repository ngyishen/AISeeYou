{
  "manifest_version": 3,
  "name": "AISeeYou",
  "version": "1.0",

  "permissions": ["storage", "downloads", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },

  "host_permissions": ["<all_urls>"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }


}